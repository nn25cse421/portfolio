<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Content Creator Portfolio</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0d0d0d;
    --surface: #161616;
    --card: #1c1c1c;
    --border: rgba(255,255,255,0.08);
    --border-hover: rgba(255,255,255,0.18);
    --text: #f0f0f0;
    --muted: #888;
    --accent: #e8ff47;
    --accent-dark: #b8cc1a;
    --red: #ff4545;
    --blue: #4a9eff;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100vh;
    padding: 0;
  }

  /* HEADER */
  .site-header {
    padding: 60px 40px 40px;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 0;
  }

  .header-left .eyebrow {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
  }

  .header-left h1 {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .header-left h1 span {
    color: var(--muted);
  }

  .header-right {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .stat {
    text-align: right;
  }

  .stat-num {
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  .stat-divider {
    width: 0.5px;
    height: 40px;
    background: var(--border);
  }

  /* FILTERS */
  .filter-bar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 40px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    border-bottom: 0.5px solid var(--border);
  }

  .filter-btn {
    font-size: 12px;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: 20px;
    border: 0.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }

  .filter-btn:hover, .filter-btn.active {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }

  /* GRID */
  .portfolio-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  /* FEATURED CARD (spans 7 cols) */
  .card-featured {
    grid-column: span 7;
  }

  /* TALL SIDE CARD (spans 5 cols) */
  .card-side {
    grid-column: span 5;
  }

  /* REGULAR CARDS (span 4 cols) */
  .card-reg {
    grid-column: span 4;
  }

  .thumb-card {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }

  .thumb-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .thumb-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #111;
  }

  .thumb-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .thumb-card:hover .thumb-img-wrap img {
    transform: scale(1.03);
  }

  .genre-pill {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
  }

  .g-podcast  { background: rgba(138,43,226,0.85); color: #e8d0ff; }
  .g-travel   { background: rgba(16,185,129,0.85); color: #d0fff0; }
  .g-invest   { background: rgba(234,179,8,0.85);  color: #3d2e00; }
  .g-opinion  { background: rgba(239,68,68,0.85);  color: #ffe0e0; }
  .g-history  { background: rgba(15,23,42,0.9);    color: #cbd5e1; border: 0.5px solid rgba(255,255,255,0.15); }

  .featured-pill {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--accent);
    color: #000;
  }

  .card-body {
    padding: 18px 20px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
  }

  .card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .tag-row {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    font-size: 11px;
    color: var(--muted);
    background: rgba(255,255,255,0.05);
    border: 0.5px solid var(--border);
    border-radius: 20px;
    padding: 3px 9px;
  }

  /* FOOTER */
  .site-footer {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 40px;
    border-top: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-note {
    font-size: 13px;
    color: var(--muted);
  }

  .footer-accent {
    color: var(--accent);
    font-weight: 600;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .site-header, .filter-bar, .portfolio-grid, .site-footer {
      padding-left: 20px;
      padding-right: 20px;
    }
    .card-featured, .card-side, .card-reg {
      grid-column: span 12;
    }
  }

  @media (max-width: 600px) {
    .site-header { padding: 32px 20px 28px; }
    .header-right { gap: 16px; }
    .stat-num { font-size: 22px; }
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-left">
    <div class="eyebrow">&#x2605; YouTube Creator</div>
    <h1>Thumbnail <span>Portfolio</span></h1>
  </div>
  <div class="header-right">
    <div class="stat">
      <div class="stat-num">5</div>
      <div class="stat-label">Thumbnails</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-num">5</div>
      <div class="stat-label">Genres</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-num">&#x221E;</div>
      <div class="stat-label">Style Range</div>
    </div>
  </div>
</header>

<nav class="filter-bar">
  <button class="filter-btn active" onclick="filterCards('all', this)">All</button>
  <button class="filter-btn" onclick="filterCards('podcast', this)">Podcast</button>
  <button class="filter-btn" onclick="filterCards('travel', this)">Travel</button>
  <button class="filter-btn" onclick="filterCards('investigative', this)">Investigative</button>
  <button class="filter-btn" onclick="filterCards('opinion', this)">Opinion</button>
  <button class="filter-btn" onclick="filterCards('history', this)">History</button>
</nav>

<main class="portfolio-grid">

  <!-- FEATURED: Hindenburg -->
  <div class="thumb-card card-featured" data-genre="history">
    <div class="thumb-img-wrap">
      <span class="genre-pill g-history">History</span>
      <span class="featured-pill">&#x2605; Featured</span>
      <img src="data:image/jpeg;base64," alt="The Hindenburg thumbnail">
    </div>
    <div class="card-body">
      <div class="card-title">The Hindenburg — Historical Documentary</div>
      <div class="card-desc">Dramatic vintage aesthetic with high-contrast B&W photography, topographic map overlay, and bold serif typography. Strong editorial tension between the archival feel and modern layout design.</div>
      <div class="tag-row">
        <span class="tag">Documentary</span>
        <span class="tag">B&amp;W Aesthetic</span>
        <span class="tag">Historical</span>
        <span class="tag">Editorial</span>
      </div>
    </div>
  </div>

  <!-- SIDE: Kailash Kher -->
  <div class="thumb-card card-side" data-genre="podcast">
    <div class="thumb-img-wrap">
      <span class="genre-pill g-podcast">Podcast</span>
      <img src="data:image/jpeg;base64," alt="Kailash Kher podcast thumbnail">
    </div>
    <div class="card-body">
      <div class="card-title">Kailash Kher Interview — Podcast</div>
      <div class="card-desc">Bold quote-card style with a verified account badge, red accent on the hook phrase, and face-forward celebrity framing optimised for high click-through rate.</div>
      <div class="tag-row">
        <span class="tag">Podcast</span>
        <span class="tag">Celebrity</span>
        <span class="tag">Quote Hook</span>
      </div>
    </div>
  </div>

  <!-- REG: Travel -->
  <div class="thumb-card card-reg" data-genre="travel">
    <div class="thumb-img-wrap">
      <span class="genre-pill g-travel">Travel</span>
      <img src="data:image/jpeg;base64," alt="Hour 1 vs Hour 19 travel thumbnail">
    </div>
    <div class="card-body">
      <div class="card-title">Hour 1 vs Hour 19 — Travel Adventure</div>
      <div class="card-desc">Split-screen contrast with dark gritty interior vs snowy alpine scenery. Face composited across both halves for emotional story arc.</div>
      <div class="tag-row">
        <span class="tag">Travel</span>
        <span class="tag">Split-Screen</span>
        <span class="tag">Before/After</span>
      </div>
    </div>
  </div>

  <!-- REG: Scammer -->
  <div class="thumb-card card-reg" data-genre="investigative">
    <div class="thumb-img-wrap">
      <span class="genre-pill g-invest">Investigative</span>
      <img src="data:image/jpeg;base64," alt="Scammer investigative documentary thumbnail">
    </div>
    <div class="card-body">
      <div class="card-title">Scammer? — Investigative Documentary</div>
      <div class="card-desc">Cork-board conspiracy aesthetic with red string connections, Polaroid-style photos, and newspaper clippings. Bold question hook drives intrigue.</div>
      <div class="tag-row">
        <span class="tag">Investigative</span>
        <span class="tag">Cork Board</span>
        <span class="tag">Mystery</span>
      </div>
    </div>
  </div>

  <!-- REG: Opinion -->
  <div class="thumb-card card-reg" data-genre="opinion">
    <div class="thumb-img-wrap">
      <span class="genre-pill g-opinion">Opinion</span>
      <img src="data:image/jpeg;base64," alt="Dictator opinion video thumbnail">
    </div>
    <div class="card-body">
      <div class="card-title">Dictator? — Political Commentary</div>
      <div class="card-desc">High-contrast red-and-blue political palette with confrontational juxtaposition framing and a bold rhetorical question as the title hook.</div>
      <div class="tag-row">
        <span class="tag">Opinion</span>
        <span class="tag">Political</span>
        <span class="tag">Contrast Design</span>
      </div>
    </div>
  </div>

</main>

<footer class="site-footer">
  <div class="footer-note">
    <span class="footer-accent">5 thumbnails</span> &nbsp;&middot;&nbsp; Podcast &middot; Travel &middot; Documentary &middot; Opinion &middot; History
  </div>
  <div class="footer-note">Built with &#x2665; for YouTube</div>
</footer>

<script>
function filterCards(genre, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.thumb-card').forEach(card => {
    if (genre === 'all' || card.dataset.genre === genre) {
      card.style.display = 'flex';
    } else {
      card.style.display = 'none';
    }
  });
}
</script>

</body>
</html>
